PORT=8080

# HH API настройки
HH_TEXT=
HH_AREA=113
HH_PER_PAGE=20
HH_PAGES=5
HH_DATE_FROM=
HH_DATE_TO=
HH_USER_AGENT=JobAggregator/1.0 (your-email@example.com)
REMOTE_JOBS_LIMIT=60
ARBEITNOW_PAGES=3
ARBEITNOW_LIMIT=90
ENBEK_PAGES=10
ENBEK_LIMIT=300
NUR_LIMIT=40
OLX_LIMIT=40
KZ_QUERY=Казахстан

# Telegram Bot API настройки
# 1) Создай бота через @BotFather
# 2) Добавь бота админом в нужные каналы
# 3) Укажи токен и usernames каналов через запятую
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNELS=devjobs,remoteit
TELEGRAM_LIMIT_PER_CHANNEL=20
# По умолчанию включены 38 каналов по всем городам КЗ (см. TELEGRAM_CHANNEL_CITY_MAP в server.js)
# Переопределите если нужны только конкретные каналы:
# TELEGRAM_PUBLIC_CHANNELS=rabotaaktau,almaty_rabota,astana_rabota,kz_jobs
TELEGRAM_PUBLIC_LIMIT_PER_CHANNEL=40

# ИИ интеграция
GEMINI_API_KEY=
